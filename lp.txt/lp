 <!DOCTYPE html>
<html lang="pt-pt">

<head>
    <meta charset="UTF-8" /> <!-- Adicionado para evitar problemas de acentuação -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="keywords" content="Função Mudar De Cor" />
    <meta name="description" content="Mudar de cor" />
    <meta name="author" content="Leandro Pinheio Da Costa Jesus Bonfim">
    <title>Mudar De Cor</title>
    <style>
        div {
            /* Ative o Flexbox para que o alinhamento funcione no centro */
            display: flex;
            justify-content: center;
            align-items: center;
            text-align: center;
            /* Garante altura para o alinhamento vertical se necessário */
            min-height: 100vh;
        }

        button {
            color: green;
            background-color: skyblue;
            width: 250px;
            height: 60px;
            font-size: 17px;
            font-weight: 700;
            border: 1px solid green;
            border-radius: 6px;
            margin-top: 100px;
            box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);

            /* CURSOR E TRANSIÇÃO FICAM AQUI (No estado base) */
            cursor: pointer;
            transition: all 0.3s ease;
        }

        button:hover {
            background-color: green;
            color: skyblue;
            /* Mudado para 1px para evitar que o botão "trema" ou mude de tamanho no hover */
            border: 1px solid skyblue;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
        }

        button.lp709 {
            margin-left: 10px;
        }

        /* MEDIA QUERY CORRIGIDA: Agora funciona em qualquer telemóvel abaixo de 400px */
        @media screen and (max-width: 700px) {
            div {
                padding: 0px 20px;
                flex-direction: column;
                box-sizing: border-box; /* Garante que o padding não quebre a largura total */
            }

            button {
                width: 100%;
                margin-top: 20px;
            }

            button.lp709 {
                margin-left: 0px;
            }
        }
    </style>
</head>

<body>
    <main>
        <section>
            <div>
                <button onclick="MudarDeCor()">Mudar Cor De Fundo</button>
                <button class="lp709" onclick="again()">Cor Branca</button>
            </div>
        </section>
    </main>
    <script>
        function MudarDeCor() {
            document.body.style.backgroundColor = '#57ff78';
            let color = 'On color green';
            console.log(color);
        }

        function again() {
            document.body.style.backgroundColor = '#ffffff';
            let color = 'On color white';
            console.log(color);
        }
    </script>
</body>

</html>
